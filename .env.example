APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TIMEZONE=UTC
DB_TIMEZONE=UTC
# Application loggers under "app" (e.g. pantry Redis CACHE HIT/MISS). Uvicorn alone does not raise them.
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg2://user:pass@db:5432/smartpantry
REDIS_URL=redis://redis:6379/0
PANTRY_LIST_CACHE_ENABLED=true
PANTRY_LIST_CACHE_TTL_SECONDS=120
PANTRY_LIST_CACHE_KEY_PREFIX=smartpantry:pantry-list
OBJECT_STORAGE_PROVIDER=s3
# Local Docker stack: app container talks to MinIO service name on port 9000.
# If you run uvicorn on the host (not in Docker), use http://127.0.0.1:9000 instead.
OBJECT_STORAGE_ENDPOINT_URL=http://minio:9000
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=smartpantry-assets
OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
# Optional. Not used by upload API today — for frontends that build absolute image URLs.
# MinIO: your public reverse-proxy base (e.g. https://cdn.example.com) if you expose objects.
# R2: Cloudflare dashboard → R2 → bucket → Public access → custom domain or *.r2.dev base URL.
OBJECT_STORAGE_PUBLIC_BASE_URL=
PANTRY_IMAGE_MAX_SIZE_BYTES=5242880
PANTRY_IMAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,https://mysmartpantry.duckdns.org
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?

SECRET_KEY=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14